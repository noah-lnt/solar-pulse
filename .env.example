# ─── PostgreSQL ───
POSTGRES_USER=solarpulse
POSTGRES_PASSWORD=solarpulse_secret
POSTGRES_DB=solarpulse
DATABASE_URL=postgresql://solarpulse:solarpulse_secret@postgres:5432/solarpulse

# ─── Auth ───
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
REGISTER_SECRET=change-me-code-inscription

# ─── Shelly Pro 3EM ───
SHELLY_IP=192.168.1.XX
SHELLY_POLL_INTERVAL_MS=2000

# ─── Hoymiles Cloud (neapi.hoymiles.com) ───
HOYMILES_DTU_IP=192.168.1.XX
HOYMILES_POLL_INTERVAL_MS=3000
HOYMILES_EMAIL=
HOYMILES_PASSWORD=
HOYMILES_STATION_ID=
HOYMILES_MS2A_STATION_ID=

# ─── Victron (Venus OS / VRM) ───
VICTRON_VENUS_IP=192.168.1.XX
VICTRON_MQTT_PORT=1883
# Si VRM cloud (fallback) :
VICTRON_VRM_TOKEN=
VICTRON_VRM_INSTALLATION_ID=

# ─── General ───
BACKEND_PORT=3001
WS_HEARTBEAT_MS=5000
DEMO_MODE=true

# ─── Traefik ───
TRAEFIK_HOST=solarpulse.nolan-sarl.fr
